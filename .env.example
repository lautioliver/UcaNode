# PostgreSQL — Neon (producción) o branch local de dev
# Pooled: usada por la app en runtime
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Directa: usada por prisma migrate deploy en build (Vercel/Neon la inyecta como DATABASE_URL_UNPOOLED)
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Formulario público para solicitar carreras faltantes en onboarding
NEXT_PUBLIC_CARRERA_SOLICITUD_FORM_URL="https://docs.google.com/forms/d/e/1FAIpQLSfk8aGnT5H3ZUOw1yox376Q4k5Fj-PTEtn7JMAeRU00c1Ttgw/viewform"

# URL base de CampuStatus (server-only).
# En desarrollo local de UcaNode usá la instancia de producción salvo que tengas
# CampuStatus corriendo en otro puerto (p. ej. http://localhost:3001).
CAMPUSSTATUS_URL="https://campu-status.vercel.app"

# Verificación de email (Resend)
# Dominio verificado en Resend: mail.ucanode.app (subdominio de ucanode.app)
RESEND_API_KEY="re_..."
EMAIL_FROM="UcaNode <noreply@mail.ucanode.app>"
APP_URL="http://localhost:3000"
