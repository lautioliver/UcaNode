generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EstadoMateria {
  CURSANDO
  PARA_FINALIZAR
  REGULAR
  FINALIZADA
}

enum TipoEntrega {
  TP
  PARCIAL
  FINAL
}

enum EstadoEntrega {
  PENDIENTE
  EN_CURSO
  ENTREGADO
}

enum CategoriaLink {
  GOOGLE_DRIVE
  PLATAFORMA_UCASAL
  GITHUB
  OTRO
}

enum Modalidad {
  PRESENCIAL
  VIRTUAL
}

enum DiaSemana {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
}

enum TipoCorrelativa {
  REGULARIZADA
  APROBADA
  PARA_RENDIR
}

enum EstadoIngesta {
  PENDIENTE
  LISTO
  ERROR
}

model Carrera {
  id            String        @id @default(cuid())
  slug          String        @unique
  nombre          String
  planAnio      String
  resolucion    String?
  modalidad     String?
  duracionAnios Int?
  estadoIngesta EstadoIngesta @default(LISTO)
  materias      PlanEstudio[]
  perfiles      Perfil[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model PlanEstudio {
  id            String               @id @default(cuid())
  codigo        String
  codigoOficial String?
  nombre        String
  abreviatura   String?
  aliases       Json                 @default("[]")
  anio          Int
  semestre      Int
  tipoDictado   String?
  creditos      Int?
  carreraId     String
  carrera       Carrera              @relation(fields: [carreraId], references: [id], onDelete: Cascade)
  correlativas  CorrelatividadPlan[] @relation("MateriaCorrelativas")
  requisitoDe   CorrelatividadPlan[] @relation("RequisitoDe")
  materias      Materia[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@unique([carreraId, codigo])
  @@index([carreraId])
  @@index([nombre])
}

model CorrelatividadPlan {
  id          String           @id @default(cuid())
  materiaId   String
  requisitoId String
  tipo        TipoCorrelativa
  materia     PlanEstudio      @relation("MateriaCorrelativas", fields: [materiaId], references: [id], onDelete: Cascade)
  requisito   PlanEstudio      @relation("RequisitoDe", fields: [requisitoId], references: [id], onDelete: Cascade)

  @@unique([materiaId, requisitoId, tipo])
}

model Perfil {
  id                      String                   @id @default(cuid())
  nombre                  String
  emailUcasal             String?                  @unique
  emailVerifiedAt         DateTime?
  anioIngreso             Int
  legajo                  String?
  password                String?
  carreraId               String?
  carrera                 Carrera?                 @relation(fields: [carreraId], references: [id])
  materias                Materia[]
  links                   LinkExterno[]
  emailVerificationTokens EmailVerificationToken[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  perfilId  String
  perfil    Perfil   @relation(fields: [perfilId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([perfilId])
}

model Materia {
  id            String         @id @default(cuid())
  nombre        String
  codigo        String?
  estado        EstadoMateria  @default(CURSANDO)
  cuatrimestre  Int?
  anio          Int?
  profesor      String?
  correlativas  String?
  notas         String?
  promocional   Boolean        @default(false)
  semestre      String?
  dia           DiaSemana?
  planEstudioId String?
  perfilId      String
  planEstudio   PlanEstudio?   @relation(fields: [planEstudioId], references: [id], onDelete: SetNull)
  perfil        Perfil         @relation(fields: [perfilId], references: [id], onDelete: Cascade)
  entregas      Entrega[]
  horarios      Horario[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([perfilId, codigo])
  @@index([estado])
  @@index([nombre])
  @@index([perfilId])
}

model Entrega {
  id                String         @id @default(cuid())
  titulo            String
  tipo              TipoEntrega
  fecha             DateTime
  estado            EstadoEntrega  @default(PENDIENTE)
  nota              Float?
  fechaInicio       DateTime?
  fechaCompletada   DateTime?
  recurso           String?
  prioridad         String?
  materiaId         String
  materia           Materia        @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([fecha])
  @@index([materiaId])
  @@index([estado])
}

model Horario {
  id            String     @id @default(cuid())
  dia           DiaSemana
  horaInicio    String
  horaFin       String
  modalidad     Modalidad  @default(PRESENCIAL)
  aulaLink      String?
  materiaId     String
  materia       Materia    @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model LinkExterno {
  id            String         @id @default(cuid())
  nombre        String
  url           String
  categoria     CategoriaLink  @default(OTRO)
  favorito      Boolean        @default(false)
  perfilId      String
  perfil        Perfil         @relation(fields: [perfilId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([perfilId])
}
